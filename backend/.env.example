PORT=4000

# Required in production — signs/verifies login session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Without it the server falls back to an insecure default and logs a warning.
JWT_SECRET=

# Leave both empty for local dev without a database (in-memory demo data).
# Fill in to use a persistent Supabase Postgres database instead — see backend/supabase/schema.sql.
# Once set, demo-mode login (any password for staff with no configured credentials) is disabled.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Comma-separated list of origins allowed to call this API via CORS. Defaults to
# http://localhost:5173 (Vite dev server) and the production Netlify URL if unset.
ALLOWED_ORIGIN=
