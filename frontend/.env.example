# Leave empty to call the API at a relative /api path (used in production via Netlify
# redirects, and in local dev via Vite's proxy). Only set for a custom API origin.
VITE_API_URL=

# Per-client branding — every value has a sensible default in src/brandConfig.js if left
# unset, so a fresh checkout still runs. Fill these in for a new client deployment, and
# replace frontend/public/logo.png with that client's logo (same filename).
VITE_BRAND_SHORT_NAME=
VITE_BRAND_FULL_NAME=
VITE_BRAND_TAGLINE=
VITE_BRAND_ADDRESS=
VITE_BRAND_ADDRESS_RU=
VITE_BRAND_PHONES=
VITE_BRAND_CONTACTS=
